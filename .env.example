# 얼마낼까 — 환경변수 (전부 선택. 없어도 서버는 내장 로직으로 동작)
#
# 천문연 음양력/특일정보 API 서비스키 (data.go.kr 15012679 / 15012690).
# 없으면 손없는날은 자체계산(음력 끝자리)으로 폴백, 음력↔양력 변환은 근사.
KASI_SERVICE_KEY=

# 카카오 로컬 API (식장/장례식장 위치·주차 조회, data.go.kr 카카오 REST 키).
# 없으면 식장 위치 정보 없이 동작.
KAKAO_REST_API_KEY=

# 서버 모드 (http = PlayMCP 배포용 / stdio = 로컬). Dockerfile에서 http로 고정.
MODE=stdio
PORT=3000
